# Clerk — https://dashboard.clerk.com → API Keys
# Copy this file to `.env.local` and fill in your keys (never commit `.env.local`).

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Share links (optional but recommended for production)
# Upstash Redis — https://upstash.com — REST URL + token. Without these, shares use in-memory storage (single instance / dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Dedicated secret for HMAC share URLs (falls back to CLERK_SECRET_KEY if unset).
SHARE_SIGNING_SECRET=
